  "motion": {
    "library": "framer-motion",
    "guidelines": {
      "page_load": "initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} transition={{ duration: 0.8, ease: 'easeOut' }}",
      "scroll_reveal": "initial={{ opacity: 0, y: 50 }} whileInView={{ opacity: 1, y: 0 }} viewport={{ once: true }} transition={{ duration: 0.8, ease: 'easeOut' }}",
      "typewriter": "Custom hook or library for 'Yoga is a technology...' quote"
    }
  },
  "admin_panel": {
    "structure": [
      "Login Screen (Simple, Clean)",
      "Dashboard (Sidebar Nav)",
      "Contacts Management (Table with shadcn/ui)",
      "Programs Management (Form + List)"
    ],
    "style": "Clean, utilitarian but using the same font family (Manrope) and softer borders. Avoid harsh contrasts."
  },
  "universal_guidelines": [
    "Use 2-3x more spacing than feels comfortable.",
    "Dark colors look good when used independently without gradients.",
    "Create depth through layered design elements.",
    "Do not use generic centered layouts everywhere.",
    "Use 'sonner' for toast notifications.",
    "Ensure all interactive elements have data-testid attributes."
  ]
}